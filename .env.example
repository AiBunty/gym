# Google Apps Script web app URL for CMS content (pricing, timings, featured event)
# Use full deployed Web App URL ending with /exec (not only Script ID).
APPS_SCRIPT_CMS_URL=https://script.google.com/macros/s/AKfycbwYlnedOOAzVnVunURHR_gf2DJSnYJC1lBx0JSVd-mWyTfirpF2Rz3QoDOiobqkqRClkg/exec

# Google Apps Script web app URL for form submissions
# Use full deployed Web App URL ending with /exec (not only Script ID).
APPS_SCRIPT_FORM_URL=https://script.google.com/macros/s/AKfycbwYlnedOOAzVnVunURHR_gf2DJSnYJC1lBx0JSVd-mWyTfirpF2Rz3QoDOiobqkqRClkg/exec

# Optional dedicated Apps Script web app URL for CMS writes from /admin
# If omitted, APPS_SCRIPT_CMS_URL will be used for both read and write.
APPS_SCRIPT_CMS_WRITE_URL=https://script.google.com/macros/s/AKfycbwYlnedOOAzVnVunURHR_gf2DJSnYJC1lBx0JSVd-mWyTfirpF2Rz3QoDOiobqkqRClkg/exec

# Required key to authorize saves from the admin control panel
ADMIN_PANEL_KEY=replace-with-strong-admin-key